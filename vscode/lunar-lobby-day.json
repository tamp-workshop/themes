  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#84786C",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.unquoted",
        "string.template",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#7A5808"
      }
    },
    {
      "name": "Number, Boolean, Null",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.none"
      ],
      "settings": {
        "foreground": "#586069"
      }
    },
    {
      "name": "Keyword, Storage",
