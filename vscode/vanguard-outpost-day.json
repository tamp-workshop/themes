  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#807890",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.unquoted",
        "string.template",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#7A4C08"
      }
    },
    {
      "name": "Number, Boolean, Null",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.none"
      ],
      "settings": {
        "foreground": "#586069"
      }
    },
    {
      "name": "Keyword, Storage",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#24292E",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
