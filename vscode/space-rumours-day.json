  "tokenColors": [
    {
      "name": "Comment",
      "scope": [
        "comment",
        "comment.line",
        "comment.block",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6A737D",
        "fontStyle": "italic"
      }
    },
    {
      "name": "String",
      "scope": [
        "string",
        "string.quoted",
        "string.unquoted",
        "string.template",
        "string.regexp"
      ],
      "settings": {
        "foreground": "#8F5E4D"
      }
    },
    {
      "name": "Number, Boolean, Null",
      "scope": [
        "constant.numeric",
        "constant.language.boolean",
        "constant.language.null",
        "constant.language.none"
      ],
      "settings": {
        "foreground": "#586069"
      }
    },
    {
      "name": "Keyword, Storage",
      "scope": [
        "keyword",
        "keyword.control",
        "storage",
        "storage.type",
        "storage.modifier"
      ],
      "settings": {
        "foreground": "#24292E",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#444D56",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Types, Classes, Interfaces",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "entity.name.namespace",
        "support.class"
      ],
      "settings": {
        "foreground": "#586069",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Variables, Parameters, Properties",
      "scope": [
        "variable",
        "variable.parameter",
        "variable.other.property",
        "entity.name.field"
      ],
      "settings": {
        "foreground": "#24292E"
      }
    },
    {
      "name": "Operators & Punctuation",
      "scope": [
        "keyword.operator",
        "punctuation",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#6A737D"
      }
    },
    {
      "name": "Markdown Headings",
      "scope": [
        "markup.heading",
        "entity.name.section.markdown"
      ],
      "settings": {
        "foreground": "#24292E",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Italic",
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#24292E",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Markdown Bold",
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#24292E",
        "fontStyle": "bold"
      }
    },
    {
      "name": "Markdown Code",
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code"
      ],
      "settings": {
        "foreground": "#444D56",
        "background": "#F3F4F6"
      }
    },
    {
      "name": "Deprecated Syntax",
      "scope": [
        "invalid.deprecated",
        "markup.strikethrough"
      ],
      "settings": {
        "foreground": "#848A94",
        "fontStyle": "strikethrough"
      }
    }
  ],
  "semanticTokenColors": {
    "namespace": {
      "foreground": "#586069",
      "italic": true
    },
    "type": {
      "foreground": "#586069",
      "italic": true
    },
    "class": {
      "foreground": "#586069",
      "italic": true
    },
    "enum": {
      "foreground": "#586069",
      "italic": true
    },
    "interface": {
      "foreground": "#586069",
      "italic": true
    },
    "parameter": {
      "foreground": "#24292E"
    },
    "variable": {
      "foreground": "#24292E"
    },
    "property": {
      "foreground": "#24292E"
    },
    "function": {
      "foreground": "#444D56",
      "bold": true
    },
    "method": {
      "foreground": "#444D56",
      "bold": true
    },
    "keyword": {
      "foreground": "#24292E",
      "bold": true
    },
    "string": {
      "foreground": "#8F5E4D"
    },
    "number": {
      "foreground": "#586069"
    },
    "comment": {
      "foreground": "#6A737D",
      "italic": true
    },
    "operator": {
      "foreground": "#6A737D"
    },
    "*.deprecated": {
      "foreground": "#848A94",
      "strikethrough": true
    }
  }
}